PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/syncscore?retryWrites=true&w=majority
NODE_ENV=development
JWT_SECRET=yoursecretjwtkeyhere

# Optional: Set your GitHub Personal Access Token
GITHUB_TOKEN=

# Groq API Configuration
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=
# Supported models: llama-3.3-70b-versatile, llama3-8b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
